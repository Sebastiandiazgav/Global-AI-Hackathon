# ============================================
# MyAgent - Enterprise AI Copilot
# Environment Variables Template
# ============================================

# Qwen Cloud Configuration (LLMs + Embeddings)
QWEN_CLOUD_API_KEY=your_qwen_cloud_api_key_here
QWEN_CLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model Configuration
SUPERVISOR_MODEL=qwen3.5-omni-plus
AGENT_MODEL=qwen3.5-omni-flash
SOCIETY_MODEL=qwen3.5-omni-plus
VISION_MODEL=qwen3-vl-235b-a22b
EMBEDDING_MODEL=text-embedding-v4

# Alibaba Cloud Infrastructure
ALIBABA_ACCESS_KEY_ID=your_access_key_here
ALIBABA_ACCESS_KEY_SECRET=your_secret_key_here
ALIBABA_REGION=ap-southeast-1

# Database (ApsaraDB RDS PostgreSQL)
DATABASE_URL=postgresql://myagent:myagent_pass@db:5432/myagent_db
DATABASE_POOL_SIZE=10

# Vector Store
VECTOR_STORE_TYPE=pgvector
VECTOR_STORE_COLLECTION=myagent_knowledge

# LangSmith Configuration (Observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=hackaton-enterprise
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Application Configuration
APP_ENV=development
APP_DEBUG=true
BACKEND_PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=INFO

# Security
GUARDRAILS_ENABLED=true
MAX_TRANSACTION_AMOUNT=500
RATE_LIMIT_PER_MINUTE=60

# Token/Context Optimization
SUPERVISOR_MAX_TOKENS=256
SUPERVISOR_HISTORY_MAX_MESSAGES=3
SUPERVISOR_HISTORY_MAX_CHARS=120
AGENT_MAX_TOKENS=1024
AGENT_CONTEXT_MAX_MESSAGES=10
AGENT_CONTEXT_MAX_CHARS=600
AGENT_TOOL_RESULT_MAX_CHARS=1500

# MCP Configuration
MCP_TRANSPORT_MODE=auto
MCP_CLIENTS_TABLE=myagent_mcp_clients
MCP_TOOL_POLICIES_TABLE=myagent_mcp_tool_policies
MCP_TOOL_AUDIT_TABLE=myagent_tool_audit

# Memory Configuration
MEMORY_MAX_MESSAGES_PER_SESSION=30
MEMORY_SESSION_TTL_MINUTES=120
MEMORY_PERSISTENT_ENABLED=true

# Multilingual Support
DEFAULT_LANGUAGE=es
SUPPORTED_LANGUAGES=es,en,fr,pt,de,it,zh
